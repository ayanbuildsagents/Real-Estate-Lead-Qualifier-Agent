      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst messages = input?.body?.messages || [];\nconst firstMsg = messages[0] || {};\n\nconst message = firstMsg?.text?.body || \"\";\nconst from = firstMsg?.from || \"\";\n\nreturn [{\n  json: {\n    message: message,\n    messageType: \"text\",\n    from: from,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
